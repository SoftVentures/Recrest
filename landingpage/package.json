{
  "name": "@recrest/landingpage",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Recrest — marketing landingpage, deployed to GitHub Pages.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"index.html\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\" \"index.html\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:ts": "tsc -b",
    "test:watch": "vitest",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@recrest/shared": "*",
    "device-type-detection": "^2.1.3",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^19.0.0",
    "react-country-flag": "^3.1.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.4",
    "simple-icons": "^16.17.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.8.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
