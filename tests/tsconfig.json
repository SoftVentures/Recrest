{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@recrest/shared": ["../shared/src/index.ts"],
      "@recrest/shared/*": ["../shared/src/*"]
    },
    "noEmit": true
  },
  "include": ["src/**/*.ts", "playwright.config.ts"]
}
