# Imprint (§ 5 DDG) — required for public landing deploys.
# Copy to .env for local dev, set via GitHub Actions secrets for CI.
# Values MUST start with VITE_ to be inlined at build time.

VITE_IMPRINT_NAME="Your legal name or company"
VITE_IMPRINT_STREET="Street and number"
VITE_IMPRINT_POSTAL_CODE="10115"
VITE_IMPRINT_CITY="Berlin"
VITE_IMPRINT_COUNTRY="Germany"
VITE_IMPRINT_EMAIL="legal@example.com"

# Optional
VITE_IMPRINT_PHONE=""
VITE_IMPRINT_RESPONSIBLE_PERSON=""
